{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Star",
  "scopeName": "source.star",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string-triple" },
    { "include": "#string-double" },
    { "include": "#char-literal" },
    { "include": "#number" },
    { "include": "#keyword" },
    { "include": "#type" },
    { "include": "#constant" },
    { "include": "#operator" },
    { "include": "#function-def" },
    { "include": "#function-call" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comment": {
      "match": "#(?!\\{).*$",
      "name": "comment.line.number-sign.star"
    },
    "string-triple": {
      "begin": "\"\"\"",
      "end": "\"\"\"",
      "name": "string.quoted.triple.star",
      "patterns": [
        { "include": "#interpolation" },
        { "include": "#escape" }
      ]
    },
    "string-double": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.star",
      "patterns": [
        { "include": "#interpolation" },
        { "include": "#escape" }
      ]
    },
    "interpolation": {
      "begin": "#\\{",
      "end": "\\}",
      "name": "meta.interpolation.star",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.interpolation.begin.star" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.interpolation.end.star" }
      },
      "patterns": [
        { "include": "source.star" }
      ]
    },
    "escape": {
      "match": "\\\\[nrt\\\\\"0]",
      "name": "constant.character.escape.star"
    },
    "char-literal": {
      "match": "'(?:[^'\\\\]|\\\\[nrt\\\\'\"])'",
      "name": "string.quoted.single.star"
    },
    "number": {
      "patterns": [
        {
          "match": "\\b\\d+\\.\\d+(?:[eE][+-]?\\d+)?\\b",
          "name": "constant.numeric.float.star"
        },
        {
          "match": "\\b\\d+\\b",
          "name": "constant.numeric.integer.star"
        }
      ]
    },
    "keyword": {
      "match": "\\b(fn|let|mut|if|then|else|end|match|when|do|for|while|in|break|continue|return|type|pub|use|module|mod|trait|impl|self|async|await)\\b",
      "name": "keyword.control.star"
    },
    "type": {
      "match": "\\b(Int|Int8|Int16|Int32|UInt|UInt8|UInt16|UInt32|Float|Float32|String|Bool|List|Map|Set|Deque|Heap|Option|Result|Ok|Err|Some|None|True|False)\\b",
      "name": "support.type.star"
    },
    "constant": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.star"
    },
    "operator": {
      "patterns": [
        {
          "match": "\\|>",
          "name": "keyword.operator.pipe.star"
        },
        {
          "match": "=>",
          "name": "keyword.operator.arrow.star"
        },
        {
          "match": "\\+\\=|-\\=|\\*\\=|/\\=|%\\=",
          "name": "keyword.operator.assignment.compound.star"
        },
        {
          "match": "==|!=|<=|>=|<|>",
          "name": "keyword.operator.comparison.star"
        },
        {
          "match": "&&|\\|\\||!",
          "name": "keyword.operator.logical.star"
        },
        {
          "match": "\\+|-|\\*|/|%",
          "name": "keyword.operator.arithmetic.star"
        },
        {
          "match": "=",
          "name": "keyword.operator.assignment.star"
        }
      ]
    },
    "function-def": {
      "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.star" },
        "2": { "name": "entity.name.function.star" }
      }
    },
    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.star" }
      }
    },
    "punctuation": {
      "patterns": [
        {
          "match": "[\\(\\)\\[\\]\\{\\}]",
          "name": "punctuation.bracket.star"
        },
        {
          "match": ",",
          "name": "punctuation.separator.star"
        },
        {
          "match": "\\|",
          "name": "punctuation.separator.pipe.star"
        }
      ]
    }
  }
}
